{
  "name": "AI EMAIL Extension",
  "description": "AI-powered email assistant for Gmail ",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://mail.google.com/*","http://localhost:8080/*"
  ],
  "action": {
    "default_title": "AI EMAIL Extension"
    
  },
  "content_scripts": [
    {
      "js": [
        "content-script.js"
      ],
      "matches": [
        "*://mail.google.com/*"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [  "icons/*" ],
      "matches": [ "*://mail.google.com/*" ]
    }
  ]
}